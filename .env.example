# Application
APP_ENV=development

# SQLite database (relative paths resolve from the project directory)
DATABASE_URL=sqlite:///./ai_fun_motion.db

# WaveSpeedAI — get a key from https://wavespeed.ai/accesskey
# Leave empty for local foundation work without provider calls.
WAVESPEED_API_KEY=

# Media generation / upload SDK endpoint (used by WaveSpeedProvider)
WAVESPEED_API_BASE_URL=https://api.wavespeed.ai

# LLM endpoint for Gate 2 prompt generation (OpenAI-compatible)
WAVESPEED_LLM_BASE_URL=https://llm.wavespeed.ai/v1
WAVESPEED_LLM_MODEL=openai/gpt-5.1
WAVESPEED_LLM_TIMEOUT_SECONDS=120

# Gate 3 base-image generation (media API — not LLM)
WAVESPEED_BASE_IMAGE_MODEL=openai/gpt-image-2/text-to-image
WAVESPEED_BASE_IMAGE_ASPECT_RATIO=9:16
WAVESPEED_BASE_IMAGE_RESOLUTION=1k
WAVESPEED_BASE_IMAGE_QUALITY=medium
WAVESPEED_BASE_IMAGE_OUTPUT_FORMAT=png
WAVESPEED_MEDIA_TIMEOUT_SECONDS=600
WAVESPEED_MEDIA_POLL_INTERVAL_SECONDS=1
BASE_IMAGE_DOWNLOAD_TIMEOUT_SECONDS=120
BASE_IMAGE_MAX_DOWNLOAD_MB=25
BASE_IMAGE_MAX_PIXELS=25000000

# Local filesystem storage root
STORAGE_ROOT=./storage

# Upload limits / Gate 4 reference + character edit
WAVESPEED_CHARACTER_EDIT_MODEL=openai/gpt-image-2/edit
WAVESPEED_CHARACTER_EDIT_ASPECT_RATIO=9:16
WAVESPEED_CHARACTER_EDIT_RESOLUTION=1k
WAVESPEED_CHARACTER_EDIT_QUALITY=medium
WAVESPEED_CHARACTER_EDIT_OUTPUT_FORMAT=png
REFERENCE_IMAGE_MAX_UPLOAD_MB=15
REFERENCE_IMAGE_MAX_PIXELS=25000000
REFERENCE_IMAGE_MIN_WIDTH=256
REFERENCE_IMAGE_MIN_HEIGHT=256

# Gate 5 source motion video (Wan 2.2 I2V — media API only)
WAVESPEED_SOURCE_VIDEO_MODEL=wavespeed-ai/wan-2.2/i2v-480p-ultra-fast
WAVESPEED_SOURCE_VIDEO_DURATION_SECONDS=5
WAVESPEED_SOURCE_VIDEO_SEED=-1
SOURCE_VIDEO_DOWNLOAD_TIMEOUT_SECONDS=300
SOURCE_VIDEO_MAX_DOWNLOAD_MB=100
SOURCE_VIDEO_MAX_DURATION_SECONDS=7
SOURCE_VIDEO_MIN_DURATION_SECONDS=4
SOURCE_VIDEO_DURATION_TOLERANCE_SECONDS=0.35
SOURCE_VIDEO_MIN_WIDTH=240
SOURCE_VIDEO_MIN_HEIGHT=400
SOURCE_VIDEO_MAX_PIXELS=5000000
SOURCE_VIDEO_MAX_FPS=60

# In-process ThreadPoolExecutor workers (Gate 1 default: 1)
LOCAL_TASK_WORKERS=1

# Media tooling (must be on PATH or absolute paths)
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
